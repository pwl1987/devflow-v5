{
  "name": "devflow-v5",
  "version": "5.0.0",
  "description": "DevFlow v5 - 企业级开发流程编排器",
  "main": "index.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint \"core/**/*.ts\" \"lib/**/*.ts\" \"src/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"core/**/*.ts\" \"lib/**/*.ts\" \"src/**/*.ts\" --fix",
    "format": "prettier --write \"core/**/*.ts\" \"lib/**/*.ts\" \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --check \"core/**/*.ts\" \"lib/**/*.ts\" \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "devflow",
    "workflow",
    "automation"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/jest-environment-puppeteer": "^5.0.6",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "deep-object-diff": "^1.1.9",
    "eslint": "^8.57.0",
    "eslint-plugin-jest": "^27.9.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
