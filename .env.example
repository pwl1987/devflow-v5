# DevFlow v5 环境配置示例
# 复制此文件为 .env 并根据需要修改配置

# ====================
# 基础配置
# ====================
NODE_ENV=development
LOG_LEVEL=info

# ====================
# 性能配置
# ====================
# 最大并发流程数
MAX_CONCURRENT_FLOWS=5
# 默认操作超时时间（毫秒）
DEFAULT_TIMEOUT_MS=300000
# 批量处理默认大小
DEFAULT_BATCH_SIZE=5
# 批量处理最大大小
MAX_BATCH_SIZE=10

# ====================
# 文件管理配置
# ====================
# 允许的文件扩展名（逗号分隔）
ALLOWED_FILE_TYPES=.ts,.js,.json,.md,.txt,.yaml,.yml
# 最大文件大小（字节）- 默认 10MB
MAX_FILE_SIZE=10485760
# 允许的路径（逗号分隔，* 表示所有路径）
ALLOWED_PATHS=/src,/lib,/tests,/core,*

# ====================
# 断点恢复配置
# ====================
# 断点存储目录
CHECKPOINT_DIR=_state/checkpoints
# 断点保留天数
CHECKPOINT_RETENTION_DAYS=30
# 是否启用断点数据完整性校验
ENABLE_CHECKSUM_VALIDATION=true

# ====================
# 审计日志配置
# ====================
# 审计日志保留天数
AUDIT_LOG_RETENTION_DAYS=90
# 是否启用审计日志
AUDIT_ENABLED=true

# ====================
# 分布式状态配置
# ====================
# 状态同步间隔（毫秒）
STATE_SYNC_INTERVAL=60000
# 冲突解决策略（LWW, FWW, MANUAL）
DEFAULT_CONFLICT_RESOLUTION=LWW

# ====================
# 开发配置
# ====================
# 是否启用调试模式
DEBUG=false
# 测试覆盖率阈值
COVERAGE_THRESHOLD=80
